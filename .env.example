# ============================================================
# CLINIC MANAGEMENT SYSTEM — Environment Variables Template
# Copy to .env and fill in values
# ============================================================

# Application
APP_NAME="ClinicManagement"
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=your-super-secret-key-change-in-production
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:19006"]

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=0
DATABASE_POOL_TIMEOUT=30

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300   # seconds

# JWT
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY_PATH=./certs/private.pem
JWT_PUBLIC_KEY_PATH=./certs/public.pem
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Azure AD B2C
AZURE_AD_B2C_TENANT_NAME=yourtenantname
AZURE_AD_B2C_CLIENT_ID=your-client-id
AZURE_AD_B2C_CLIENT_SECRET=your-client-secret
AZURE_AD_B2C_POLICY_NAME=B2C_1_signupsignin
AZURE_AD_B2C_AUTHORITY=https://yourtenantname.b2clogin.com/yourtenantname.onmicrosoft.com

# Azure Storage
AZURE_STORAGE_ACCOUNT_NAME=yourstorageaccount
AZURE_STORAGE_ACCOUNT_KEY=your-storage-account-key
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_STORAGE_CONTAINER_NAME=clinic-files
AZURE_STORAGE_CDN_URL=https://your-cdn.azureedge.net

# Azure Communication Services
AZURE_COMMUNICATION_CONNECTION_STRING=endpoint=https://...
AZURE_COMMUNICATION_SENDER_EMAIL=noreply@clinicapp.com
AZURE_COMMUNICATION_SENDER_PHONE=+1234567890

# Azure Service Bus
AZURE_SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://...
AZURE_SERVICE_BUS_QUEUE_NOTIFICATIONS=clinic-notifications
AZURE_SERVICE_BUS_QUEUE_TASKS=clinic-tasks

# Azure Key Vault
AZURE_KEY_VAULT_URL=https://your-keyvault.vault.azure.net/
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-managed-identity-client-id

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Email (SendGrid / Azure)
SENDGRID_API_KEY=SG.your-sendgrid-api-key
EMAIL_SENDER_ADDRESS=noreply@clinicapp.com
EMAIL_SENDER_NAME="ClinicManagement"

# SMS (Twilio)
TWILIO_ACCOUNT_SID=ACyour-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+1234567890
    
# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# Payment (Stripe)
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# Telemedicine (Azure Communication Services WebRTC)
ACS_ENDPOINT=https://your-acs.communication.azure.com/
ACS_ACCESS_KEY=your-acs-access-key

# Drug Database API
DRUG_API_URL=https://api.drugbank.com/v1
DRUG_API_KEY=your-drug-api-key

# ICD-10 API
ICD_API_URL=https://clinicaltables.nlm.nih.gov/api/icd10cm/v3

# Monitoring
AZURE_APPLICATION_INSIGHTS_KEY=your-app-insights-key
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# Feature Flags
FEATURE_TELEMEDICINE=true
FEATURE_PHARMACY=true
FEATURE_INSURANCE=true
FEATURE_AI_DIAGNOSIS_ASSIST=false

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST=20

# Encryption
PHI_ENCRYPTION_KEY=your-32-byte-base64-encoded-key   # For sensitive field encryption
