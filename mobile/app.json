{
  "expo": {
    "name": "ClinicManagement",
    "slug": "clinic-management",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e40af"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.clinicmanagement.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "We need camera access for telemedicine video calls and document scanning.",
        "NSMicrophoneUsageDescription": "We need microphone access for telemedicine video calls.",
        "NSPhotoLibraryUsageDescription": "We need photo library access to upload medical documents and profile photos.",
        "NSFaceIDUsageDescription": "Use Face ID for secure login."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e40af"
      },
      "package": "com.clinicmanagement.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECORD_AUDIO",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1e40af",
          "sounds": [
            "./assets/notification-sound.wav"
          ]
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow ClinicManagement to access your camera."
        }
      ],
      "expo-local-authentication",
      "expo-localization"
    ],
    "scheme": "clinicmanagement",
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
